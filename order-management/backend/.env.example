# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/order-management

# Scheduler security
SCHEDULER_SECRET_KEY=change-this-to-a-long-random-secret

# CORS
FRONTEND_ORIGIN=http://localhost:5173

# Status transition timing (in minutes) - optional overrides
PLACED_TO_PROCESSING_MINUTES=10
PROCESSING_TO_READY_MINUTES=20
